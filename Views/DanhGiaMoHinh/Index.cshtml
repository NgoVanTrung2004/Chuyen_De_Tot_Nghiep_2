@model List<QuanLyPhongKhachSan.Models.DanhGiaMoHinh>

<h2 class="mb-4">
    Đánh Giá Mô Hình Dự Báo
</h2>

<div class="row mb-4">

    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Số mô hình</h5>
                <h2>@Model.Count()</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>RMSE thấp nhất</h5>
                <h2>@Model.Min(x => x.Rmse)</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-warning text-dark">
            <div class="card-body">
                <h5>MAPE thấp nhất</h5>
                <h2>@Model.Min(x => x.Mape)%</h2>
            </div>
        </div>
    </div>

</div>

<table class="table table-striped table-hover table-bordered shadow">
    <thead class="table-dark">
        <tr>
            <th>Mô hình</th>
            <th>RMSE</th>
            <th>MAE</th>
            <th>MAPE</th>
            <th>Ngày đánh giá</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>

                    @if (item.TenMoHinh == "ARIMA")
                    {
                        <span class="badge bg-primary">
                            ARIMA
                        </span>
                    }
                    else if (item.TenMoHinh == "Prophet")
                    {
                        <span class="badge bg-info">
                            Prophet
                        </span>
                    }
                    else
                    {
                        @item.TenMoHinh
                    }

                </td>
                <td>

                    @if ((item.Rmse ?? 0) < 11)
                    {
                        <span class="badge bg-success">
                            @item.Rmse
                        </span>
                    }
                    else if ((item.Rmse ?? 0) < 15)
                    {
                        <span class="badge bg-warning text-dark">
                            @item.Rmse
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            @item.Rmse
                        </span>
                    }

                </td>
                <td>@item.Mae</td>
                <td>

                    @if ((item.Mape ?? 0) < 20)
                    {
                        <span class="badge bg-success">
                            @item.Mape
                        </span>
                    }
                    else if ((item.Mape ?? 0) < 30)
                    {
                        <span class="badge bg-warning text-dark">
                            @item.Mape
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            @item.Mape
                        </span>
                    }

                </td>
                <td>

                    @(
                    item.NgayDanhGia?.ToString("dd/MM/yyyy")
                    )

                </td>
            </tr>
        }
    </tbody>

</table>