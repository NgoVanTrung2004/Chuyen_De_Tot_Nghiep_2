@model IEnumerable<QuanLyPhongKhachSan.Models.CongSuatPhong>

@{
    ViewData["Title"] = "Danh sách công suất phòng";
}

<h2>Danh sách công suất phòng</h2>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Mã</th>
            <th>Ngày</th>
            <th>Tổng phòng</th>
            <th>Phòng đã đặt</th>
            <th>Tỷ lệ công suất</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaCongSuat</td>
                <td>@item.Ngay</td>
                <td>@item.TongPhong</td>
                <td>@item.PhongDaDat</td>
                <td>@item.TyLeCongSuat</td>
            </tr>
        }
    </tbody>
</table>